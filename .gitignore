# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
app.db

# env files (secrets stay local; template is committed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# Local reference project (not published; branding lives in app/)
Example/

# Python web app (FastAPI)
pyweb/.venv/
pyweb/data/
pyweb/client_workspaces/
pyweb/**/__pycache__/
__pycache__/
*.py[cod]
*.pyo

# User-generated content (uploaded avatars, temp scripts)
pyweb/upos/static/avatars/
pyweb/upos/static/hr-photos/
scratch/

# Deprecated Next.js tree (optional archive folder)
_legacy_nextjs/.next/
_legacy_nextjs/node_modules/

# Cursor / local agent artifacts
.cursor/
.agent/
.gemini/
.pw-yestask-profile/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
