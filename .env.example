# ============================================================
# U-POS FINANCE — переменные окружения
# Локально: скопировать в `.env.local` в корне репозитория или в `pyweb/.env`.
# Railway: Project → ваш сервис → Variables — вставить те же имена и значения.
# Хранилище: Railway PostgreSQL (DATABASE_URL / DATABASE_PUBLIC_URL).
# Локальные JSON-файлы больше не используются как источник данных приложения.
# ============================================================

# --- Обязательно в продакшене ---
# Секрет подписи cookie-сессий (локально можно оставить пустым с предупреждением в логе).
AUTH_SECRET=

# Опубликованный HTTPS-URL приложения (для ссылок из писем/интеграций, если понадобится).
# Пример Railway: https://ваш-сервис.up.railway.app
AUTH_URL=https://your-app.up.railway.app

# Первый администратор: создаётся только если таблица users пуста.
ADMIN_BASIC_USER=
ADMIN_BASIC_PASSWORD=
ADMIN_DISPLAY_NAME=Администратор

# --- Railway / платформа ---
# Порт задаёт Railway автоматически — переменную PORT вручную не выставлять.
# RAILWAY_ENVIRONMENT=production — выставляет Railway сам; включает Secure-cookie для сессий.

# Принудительно Secure-сессию (поверх продакшена Railway): SESSION_HTTPS_ONLY=true

# --- PostgreSQL (Railway) ---
# Railway добавляет переменные к сервису Postgres; у ВЕБ-сервиса должна быть
# хотя бы одна из опций ниже скопировать ссылкой (Variable reference) или вручную:
#   • DATABASE_URL (предпочтительно, внутренний host …railway.internal…)
#   • или DATABASE_PUBLIC_URL
#   • или набор PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE (как в Variables у Postgres)
# DATABASE_URL=postgresql://postgres:...@postgres-xxx.railway.internal:5432/railway
# DATABASE_PUBLIC_URL=postgresql://postgres:...@turntable.proxy.rlwy.net:35016/railway
#
# Одноразовый импорт старых JSON (если они есть локально):
# cd pyweb && python -m upos.migrate_json_to_postgres --overwrite

# --- Производительность PostgreSQL при старте ---
# На Railway после первого деплоя схема уже выровнена — ускоряет рестарт:
# UPOS_SKIP_SCHEMA_ALIGN=1
# UPOS_SCHEMA_ALIGN_ON_START=0
# UPOS_DB_CONNECT_TIMEOUT=5
# UPOS_USER_CACHE_TTL=45

# --- Прочее (позже) ---
# SMS_PROVIDER_API_KEY=
